# ===== Protheus =====
# URL base da API REST exposta pelo Protheus (TLPP/Rest Framework)
PROTHEUS_BASE_URL=https://protheus.suaempresa.com.br:8080/rest
PROTHEUS_API_KEY=coloque_aqui_a_chave_ou_token

# ===== Oracle Cloud HCM =====
ORACLE_BASE_URL=https://seu-ambiente.fa.ocs.oraclecloud.com
ORACLE_OAUTH_TOKEN_URL=https://idcs-seu-tenant.identity.oraclecloud.com/oauth2/v1/token
ORACLE_CLIENT_ID=coloque_aqui_o_client_id
ORACLE_CLIENT_SECRET=coloque_aqui_o_client_secret
ORACLE_OAUTH_SCOPE=https://seu-ambiente.fa.ocs.oraclecloud.com/urn:opc:resource:fa:instanceid=seu-instance-id

# ===== Comportamento da integração =====
# Intervalo do polling em formato cron (padrão: a cada 5 minutos)
POLLING_CRON=*/5 * * * *

# Número máximo de tentativas antes de marcar como erro definitivo
MAX_TENTATIVAS=5

# Código de motivo padrão do Oracle quando não houver mapeamento específico
ORACLE_MOTIVO_PADRAO=VOLUNTARY

# ===== Notificação de falhas =====
NOTIFICACAO_EMAIL_DESTINO=rh-ti@suaempresa.com.br

# ===== Geral =====
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
